{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "WebsiteTravel Developer Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Agent / Reseller API",
            "openapi": {
              "source": "openapi/agent-reseller-api.json",
              "directory": "api-reference/agent-reseller-api"
            }
          },
          {
            "group": "Freelance Agent API",
            "openapi": {
              "source": "openapi/freelance-agent-api.json",
              "directory": "api-reference/freelance-agent-api"
            }
          },
          {
            "group": "EBS Supplier API",
            "openapi": {
              "source": "openapi/ebs-supplier-api.json",
              "directory": "api-reference/ebs-supplier-api"
            }
          },
          {
            "group": "Freelance Internal API",
            "openapi": {
              "source": "openapi/freelance-internal-api.yaml",
              "directory": "api-reference/freelance-internal-api"
            }
          },
          {
            "group": "Website Travel Supplier API",
            "openapi": {
              "source": "openapi/website-travel-supplier-api.json",
              "directory": "api-reference/website-travel-supplier-api"
            }
          },
          {
            "group": "Tourbuilder API",
            "openapi": {
              "source": "openapi/tourbuilder-api.openapi.json",
              "directory": "api-reference/tourbuilder-api"
            }
          },
          {
            "group": "Ibis API",
            "openapi": {
              "source": "openapi/ibis-api.openapi.json",
              "directory": "api-reference/ibis-api"
            }
          },
          {
            "group": "AccomSOA API",
            "openapi": {
              "source": "openapi/accomsoa-api.openapi.json",
              "directory": "api-reference/accomsoa-api"
            }
          },
          {
            "group": "TransportSOA API",
            "openapi": {
              "source": "openapi/transportsoa-api.openapi.json",
              "directory": "api-reference/transportsoa-api"
            }
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API overview",
          "href": "/api-reference/introduction",
          "icon": "terminal"
        },
        {
          "anchor": "Mintlify docs",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api@websitetravel.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "View APIs",
      "href": "/api-reference/introduction"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  }
}
